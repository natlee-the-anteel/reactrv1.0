rule meme_promoters:
    input: output/DELLA_family/domain_sorted/promoters/GRAS_promoters.fasta
    output: output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.xml, output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.html, output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/SKIPPED
    jobid: 41
    reason: Missing output files: output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.html; Input files updated by another job: output/DELLA_family/domain_sorted/promoters/GRAS_promoters.fasta
    wildcards: query=DELLA_family, domain=GRAS
    resources: tmpdir=/var/folders/dt/51mysmg16mx90ht205m8fq380000gp/T


        # Count sequences in the fasta
        seq_count=$(grep -c ">" output/DELLA_family/domain_sorted/promoters/GRAS_promoters.fasta || true)

        if [ "$seq_count" -lt 1 ]; then
            echo "Too few sequences ($seq_count). Skipping MEME."
            mkdir -p $(dirname output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.xml)
            touch output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/SKIPPED
            # Create dummy files so Snakemake is happy
            touch output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.xml output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.html
        else
            meme output/DELLA_family/domain_sorted/promoters/GRAS_promoters.fasta -dna -oc $(dirname output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/meme.xml) -mod zoops -nmotifs 10 -minw 6 -maxw 50 -revcomp
            # CRITICAL: Create the SKIPPED file as a placeholder even if we didn't skip
            touch output/DELLA_family/domain_sorted/promoters/meme_results/GRAS/SKIPPED
        fi
        
